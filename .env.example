# ─── required ──────────────────────────────────────────────────────────────
# The wallet that pays tx fees and receives all farmed SOL.
# Either a base58 string OR a JSON array of 64 bytes (Solana CLI format).
# Example (JSON array, same as ~/.config/solana/id.json):
#   MAIN_WALLET_SECRET=[12,34,56, ... ,7,8,9]
# Example (base58):
#   MAIN_WALLET_SECRET=5fZ...abc
MAIN_WALLET_SECRET=

# ─── network ───────────────────────────────────────────────────────────────
# Solana devnet RPC. Override to use Helius/QuickNode/etc.
RPC_URL=https://api.devnet.solana.com

# Optional proxy for RPC calls. Bypasses the per-IP rate limit on the public
# devnet RPC — highly recommended when running more than 2-3 pipelines.
# Supports http://, https://, socks4://, socks5://.
# Leave empty to go direct from your machine's IP.
# PROXY_URL=socks5://user:pass@host:port
PROXY_URL=

# ─── mining & throughput ───────────────────────────────────────────────────
# How many claims to run in parallel. Each pipeline mines its own keypair
# and submits its own tx. Rough guidance:
#   - No proxy:    2-3 pipelines (avoid 429s from the RPC)
#   - With proxy:  4-8 pipelines
POW_PIPELINES=3

# Mining threads per pipeline. Total CPU load ≈ POW_PIPELINES × this value.
# Leave some cores free for the OS so your machine stays responsive.
POW_WORKERS_PER_PIPELINE=3

# Hardest faucet difficulty we'll try to mine. Expected tries ≈ 58^N:
#   3 → ~195k tries (<1 s)
#   4 → ~11M tries  (~3 s with 3 workers)
#   5 → ~656M tries (~2 min with 8 workers)
# Set 3 for safe continuous farming, 4 if you want to attempt bigger rewards.
MAX_DIFFICULTY=4

# Batch & cycle pacing. Pausing between batches lets the RPC rate-limit
# window reset — increase if you still see 429s.
BATCH_SIZE=50
BATCH_SLEEP_MS=30000

# ─── optional http api ─────────────────────────────────────────────────────
# If set, exposes POST /distribute { destination, sol } for your backend to
# pull SOL from the farmed main wallet. Leave unset to run farming only.
# API_TOKEN=replace_with_a_random_secret
API_PORT=3000
MAX_DISTRIBUTE_SOL=5
